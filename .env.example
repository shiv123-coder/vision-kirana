# ==============================================================
# VISIONKIRANA MASTER CONFIGURATION REFERENCE
# ==============================================================
# This file serves as a master reference and is used exclusively 
# by the root docker-compose.yml for local orchestration.
#
# DO NOT use this file for deployed services.
# Each microservice (frontend, backend, ml-service) has its own 
# dedicated .env.example inside its respective directory.
# ==============================================================

# --- Backend API Environment Variables ---
PROJECT_NAME="VisionKirana"
SECRET_KEY="super-secret-key-change-in-prod"
ACCESS_TOKEN_EXPIRE_MINUTES=43200
FRONTEND_URL="https://vision-kirana.vercel.app"
ML_API_BASE_URL="https://visionkirana-ml-service.onrender.com/api/v1"
SQLALCHEMY_DATABASE_URI="postgresql://user:password@db/visionkirana"
ADMIN_EMAIL="admin@visionkirana.com"

# --- ML Service Environment Variables ---
ENVIRONMENT="production"
BACKEND_API_URL="https://visionkirana-api.onrender.com/api/v1"
MAX_FILE_SIZE_MB=10

# --- Frontend Environment Variables ---
VITE_API_BASE_URL="https://visionkirana-api.onrender.com/api/v1"
VITE_ML_API_BASE_URL="https://visionkirana-ml-service.onrender.com/api/v1"
VITE_GOOGLE_CLIENT_ID="your_google_client_id_here"

# --- Shared External API Keys ---
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
GOOGLE_CLIENT_ID="your_google_client_id_here"

# --- Docker Postgres DB Settings ---
POSTGRES_SERVER="db"
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="visionkirana"
